{
  "name": "@payflow/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"nest build --watch\" \"sh -c 'until [ -f dist/apps/api/src/main.js ]; do sleep 1; done; node --watch dist/apps/api/src/main.js'\"",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
    "seed": "tsx src/modules/database/seed.ts",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.1",
    "@nestjs/core": "^11.1.1",
    "@nestjs/platform-express": "^11.1.1",
    "@payflow/shared": "0.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ethers": "^6.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.1",
    "@types/node": "^22.15.21",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
